# Environment variable template
# Copy this file to .env and fill your real values before running.

# ===== Weibo local city crawler =====
WEIBO_CONTAINERID=请替换为你的微博同城containerid
WEIBO_LUICODE=10000011
WEIBO_LFID=102803
WEIBO_USER_AGENT=Mozilla/5.0 (Linux; Android 6.0; Nexus 5 Build/MRA58N) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/131.0.0.0 Mobile Safari/537.36
WEIBO_XSRF_TOKEN=请替换为你的微博XSRFToken
WEIBO_COOKIE_T_WM=请替换为你的_T_WM
WEIBO_COOKIE_WEIBOCN_FROM=1110006030
WEIBO_COOKIE_SUB=请替换为你的SUB
WEIBO_COOKIE_XSRF=请替换为你的XSRF-TOKEN

# ===== LLM recognition =====
LLM_ENABLED=true
LLM_API_KEY=请替换为你的模型APIKey
LLM_BASE_URL=http://127.0.0.1:2048/v1
LLM_MODEL=gemini-2.0-flash
LLM_BATCH_SIZE=10
LLM_MAX_TOKENS=1500

# ===== Runtime =====
RUNTIME_PAGES=3
RUNTIME_INTERVAL=3600
RUNTIME_THRESHOLD=0.5
RUNTIME_SLEEP_SECONDS=0.5
